<Page x:Class="YoloAOIApp.Views.InferenceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inference - Measure Distance"
      Background="#FFFFFF">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Controls -->
        <StackPanel Grid.Column="0" Margin="20" VerticalAlignment="Top">
            <TextBlock Text="Distance Measurement" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <Button x:Name="LoadConfigButton" 
                    Content="Load Configuration" 
                    Padding="10,8" 
                    FontSize="12"
                    Margin="0,0,0,0"
                    Command="{Binding LoadConfigCommand}"
                    CommandParameter="config"
                    Background="#0078D4" Foreground="White" FontWeight="Bold"/>

            <TextBlock Text="Upload Image:" FontWeight="Bold" Margin="0,10,0,5"/>
            <Button x:Name="UploadButton" 
                    Content="Select Image" 
                    Padding="10,8" 
                    FontSize="12"
                    Margin="0,0,0,0"
                    Click="UploadButton_Click"
                    Background="#107C10" Foreground="White" FontWeight="Bold"/>

            <Button x:Name="RunButton" 
                    Content="Run Inference" 
                    Padding="10,8" 
                    FontSize="12"
                    Margin="0,8,0,0"
                    Command="{Binding RunInferenceCommand}"
                    Background="#0078D4" Foreground="White" FontWeight="Bold"/>

            <Separator Margin="0,10"/>

            <TextBlock Text="Results:" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBlock Text="{Binding MeasurementText}" 
                       TextWrapping="Wrap" 
                       Foreground="#323130"
                       Background="#F3F2F1"
                       Padding="10"
                       MinHeight="40"
                       FontSize="14"
                       FontWeight="SemiBold"/>

            <Separator Margin="0,10"/>

            <TextBlock Text="Status:" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBlock Text="{Binding StatusMessage}" 
                       TextWrapping="Wrap" 
                       Foreground="#323130"
                       Background="#F3F2F1"
                       Padding="10"
                       MinHeight="60"/>
        </StackPanel>

        <!-- Right Panel: Result Image -->
        <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,20,20,20">
            <Grid>
                <Image x:Name="ResultImage" 
                       Source="{Binding ResultImage}" 
                       Stretch="Uniform"/>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page x:Class="YoloAOIApp.Views.SetupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:YoloAOIApp.Converters"
      Title="Setup - Select Objects and Click Direction Points"
      Background="#FFFFFF">
    <Page.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Controls with ScrollViewer to prevent clipping -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#F9F9F9">
            <StackPanel Margin="20" VerticalAlignment="Top">
                <TextBlock Text="Setup Configuration" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#0078D4"/>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Object A Class:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ObjectACombo" 
                              ItemsSource="{Binding AvailableClasses}" 
                              SelectedItem="{Binding SelectedObjectA}"
                              DisplayMemberPath="DisplayName"
                              Height="35"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Object B Class:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ObjectBCombo" 
                              ItemsSource="{Binding AvailableClasses}" 
                              SelectedItem="{Binding SelectedObjectB}"
                              IsEnabled="{Binding UseSameObject, Converter={StaticResource InverseBooleanConverter}}"
                              DisplayMemberPath="DisplayName"
                              Height="35"/>
                </StackPanel>

                <CheckBox Content="Measure Same Object" 
                          IsChecked="{Binding UseSameObject}" 
                          Margin="0,0,0,20"
                          FontSize="13"
                          FontWeight="SemiBold"/>

                <Button x:Name="SetupButton" 
                        Content="1. Load / Start Setup" 
                        Padding="10,10" 
                        Margin="0,0,0,8"
                        Command="{Binding SetupCommand}"
                        CommandParameter="setup"
                        Background="#0078D4" Foreground="White" FontWeight="Bold"/>

                <Button x:Name="LoadImageButton" 
                        Content="2. Load Setup Image" 
                        Padding="10,10" 
                        Margin="0,0,0,8"
                        Command="{Binding LoadImageCommand}"
                        Background="#107C10" Foreground="White" FontWeight="Bold"/>

                <Button x:Name="ResetButton" 
                        Content="Reset Click Points" 
                        Padding="10,10" 
                        Margin="0,0,0,8"
                        Command="{Binding ResetPointsCommand}"
                        Background="#DA3B01" Foreground="White" FontWeight="Bold"/>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Calculation Method:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableCalculationMethods}" 
                              SelectedItem="{Binding SelectedCalculationMethod}"
                              Height="35"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15" IsEnabled="{Binding IsOffsetObjectSelected}">
                    <TextBlock Text="Offset Result:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OffsetMeasurementOptions}"
                              SelectedItem="{Binding SelectedOffsetMeasurement}"
                              Height="35"/>
                </StackPanel>

                <Button x:Name="AddRuleButton" 
                        Content="3. Add Measurement Rule" 
                        Padding="10,12" 
                        Margin="0,0,0,8"
                        Command="{Binding AddRuleCommand}"
                        Background="#0078D4" Foreground="White" FontWeight="Bold"/>

                <Button x:Name="SaveButton" 
                        Content="4. Save ALL Rules to Config" 
                        Padding="10,12" 
                        Margin="0,0,0,20"
                        Command="{Binding SaveConfigCommand}"
                        Background="#107C10" Foreground="White" FontWeight="Bold"/>

                <TextBlock Text="Registered Rules:" FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
                <DataGrid ItemsSource="{Binding MeasurementRules}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          Height="150"
                          Margin="0,0,0,20"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dist ID" Binding="{Binding DistanceName}" Width="Auto"/>
                        <DataGridTextColumn Header="Rule" Binding="{Binding RuleName}" Width="*"/>
                        <DataGridTemplateColumn Header="Min Distance" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding MinDist, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Max Distance" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding MaxDist, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Calculation Method" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding CalculationMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding RelativeSource={RelativeSource AncestorType={x:Type Page}}, Path=DataContext.AvailableCalculationMethods}"
                                              VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Del" 
                                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}"
                                            Background="#DA3B01" Foreground="White" FontSize="10" Padding="5,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Calibration (mm/pixel):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding PixelToMmRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" VerticalContentAlignment="Center" Padding="4"/>
                    <TextBlock Text="1.0 = pixels only. Enter mm/pixel ratio for real-world units." 
                               FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>

                <Separator Margin="0,0,0,20"/>

                <TextBlock Text="Instructions:" FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
                <TextBlock Text="• Select classes &amp; mode" Margin="0,0,0,4"/>
                <TextBlock Text="• Load Model &amp; Image" Margin="0,0,0,4"/>
                <TextBlock Text="• Click object for Ray A" Margin="0,0,0,4"/>
                <TextBlock Text="• Click object for Ray B" Margin="0,0,0,4"/>
                <TextBlock Text="• Save and use in Inference" Margin="0,0,0,20"/>

                <Separator Margin="0,0,0,20"/>

                <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
                <Border Background="#F3F2F1" CornerRadius="4" BorderBrush="#E1E1E1" BorderThickness="1">
                    <TextBlock Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap" 
                               Foreground="#323130"
                               Padding="12"
                               MinHeight="100"
                               FontSize="13"
                               LineHeight="18"/>
                </Border>
                
                <!-- Extra space at bottom of scroll -->
                <FrameworkElement Height="20"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel: Image Display -->
        <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,20,20,20" Background="Black">
            <Grid>
                <Image x:Name="DisplayImage" 
                       Source="{Binding DisplayImage}" 
                       MouseDown="Image_MouseDown"
                       Stretch="Uniform"/>
            </Grid>
        </Border>
    </Grid>
</Page>
